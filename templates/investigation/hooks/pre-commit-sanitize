#!/usr/bin/env bash
# pre-commit-sanitize: blocks commits of unsanitized investigation files
# Install to .git/hooks/pre-commit in investigation repos
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SANITIZE_SCRIPT="$HOME/.claude/scripts/sanitize.sh"

# Only check .md files staged for commit
staged_md=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)
if [ -z "$staged_md" ]; then
  exit 0
fi

if [ ! -x "$SANITIZE_SCRIPT" ]; then
  echo "WARNING: sanitize.sh not found at $SANITIZE_SCRIPT — skipping PII check"
  exit 0
fi

failed=0
while IFS= read -r file; do
  if [ ! -f "$file" ]; then
    continue
  fi
  result=$("$SANITIZE_SCRIPT" --check "$file" 2>/dev/null || true)
  if echo "$result" | grep -q "PII_FOUND"; then
    echo "BLOCKED: $file contains unsanitized PII/PHI. Run sanitize.sh on this file before committing."
    failed=1
  fi
done <<< "$staged_md"

exit $failed
