#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: auto-sanitize investigation files for PII/PHI.
# Principle: auto-sanitize on commit, never reject.
#
# 1. Blocks EVIDENCE/ files from staging (local-only raw data)
# 2. Runs sanitize.sh on staged BRIEF.md, FINDINGS.md, STATUS.md
# 3. Re-stages sanitized files automatically

SANITIZE_SCRIPT="${HOME}/.claude/scripts/sanitize.sh"

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED" ]; then
    exit 0
fi

# --- Block EVIDENCE/ files (local-only raw data) ---

EXIT_CODE=0
while IFS= read -r file; do
    [ -z "$file" ] && continue
    case "$file" in
        */EVIDENCE/*)
            echo "Error: $file must not be committed (local-only raw data)" >&2
            EXIT_CODE=1
            ;;
    esac
done <<EOF
$STAGED
EOF

if [ "$EXIT_CODE" -ne 0 ]; then
    echo "Unstage EVIDENCE/ files before committing." >&2
    exit "$EXIT_CODE"
fi

# --- PHI Sanitization ---

# Collect investigation markdown files to sanitize
FILES_TO_SANITIZE=()
while IFS= read -r file; do
    [ -z "$file" ] && continue
    case "$file" in
        */BRIEF.md|*/FINDINGS.md|*/STATUS.md)
            FILES_TO_SANITIZE+=("$file")
            ;;
    esac
done <<EOF
$STAGED
EOF

if [ ${#FILES_TO_SANITIZE[@]} -eq 0 ]; then
    exit 0
fi

if [ ! -x "$SANITIZE_SCRIPT" ]; then
    echo "Note: sanitize.sh not found at $SANITIZE_SCRIPT. Skipping auto-sanitization." >&2
    echo "  Review investigation files for PII/PHI before sharing." >&2
    exit 0
fi

# Run sanitization
"$SANITIZE_SCRIPT" "${FILES_TO_SANITIZE[@]}" || true

# Re-stage sanitized files
for file in "${FILES_TO_SANITIZE[@]}"; do
    git add "$file"
done

exit 0
