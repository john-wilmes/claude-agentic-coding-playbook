#!/usr/bin/env bash
# Pre-commit hook: warn if investigation files may contain PII/PHI
# Install: cp this file to .git/hooks/pre-commit in your investigations repo
# Requires: presidio-analyzer (pip install presidio-analyzer)

set -euo pipefail

if ! python3 -c "import presidio_analyzer" 2>/dev/null; then
  echo "WARNING: presidio-analyzer not installed. Skipping PII/PHI check."
  echo "  Install: pip install presidio-analyzer presidio-anonymizer"
  exit 0
fi

CONFIG="${HOME}/.claude/templates/investigation/presidio.yaml"

if [ ! -f "$CONFIG" ]; then
  echo "WARNING: No .presidio.yaml found at $CONFIG. Skipping PII/PHI check."
  exit 0
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(md|txt)$' || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

echo "Checking staged investigation files for PII/PHI..."

FOUND_PII=false
while IFS= read -r file; do
  [ -z "$file" ] && continue
  RESULT=$(python3 -c "
import sys
from presidio_analyzer import AnalyzerEngine
analyzer = AnalyzerEngine()
with open(sys.argv[1], 'r') as f:
    text = f.read()
results = analyzer.analyze(text=text, language='en')
for r in results:
    print(f'  {r.entity_type} (score: {r.score:.2f}) at position {r.start}-{r.end}')
" "$file" 2>/dev/null || true)

  if [ -n "$RESULT" ]; then
    echo "PII/PHI detected in $file:"
    echo "$RESULT"
    FOUND_PII=true
  fi
done <<< "$STAGED"

if [ "$FOUND_PII" = true ]; then
  echo ""
  echo "PII/PHI detected in staged files. Options:"
  echo "  1. Run /investigate <id> close to auto-sanitize"
  echo "  2. Manually redact the flagged content"
  exit 1
fi

echo "No PII/PHI detected."
