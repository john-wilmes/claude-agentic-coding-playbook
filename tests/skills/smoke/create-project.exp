#!/usr/bin/env expect
# tests/skills/smoke/create-project.exp — Interactive test for /create-project skill
#
# Expects PROJECT_NAME env var from wrapper script.
# Uses --append-system-prompt to guide the LLM's choices for project type/description
# so AskUserQuestion is answered by the LLM itself.

set timeout 300

set project_name $env(PROJECT_NAME)

# Start claude with MCP disabled to avoid interference and system prompt guidance
spawn claude --model haiku --permission-mode bypassPermissions \
    --mcp-config {{"mcpServers":{}}} --strict-mcp-config \
    --append-system-prompt "When creating a project: choose Node/TypeScript as the project type and use 'Smoke test project' as the description. Do NOT create a GitHub repo (skip the gh repo create step). Do NOT run CodeRabbit review. Answer any AskUserQuestion prompts yourself using these choices."

# Wait for TUI to fully initialize
sleep 8

# Type the command with deliberate pacing for the autocomplete system
send "/create-project $project_name"
sleep 3

# Press Enter to select from autocomplete and submit
send "\r"
sleep 2

# Send a second Enter in case the first only selected the autocomplete item
send "\r"

# Wait for the skill to complete
# The LLM should make its own choices based on the system prompt
# Handle any unexpected interactive prompts
expect {
    -re {\[y/N\]} {
        sleep 1
        send "N\r"
        exp_continue
    }
    -re {\[Y/n\]} {
        sleep 1
        send "Y\r"
        exp_continue
    }
    -re {(?i)(created|scaffolded|project.*path|report|complete|done|next step)} {
        puts "\nPASS: create-project produced completion output"
    }
    timeout {
        puts "\nWARN: create-project timed out — checking side effects"
    }
    eof {
        puts "\nINFO: process ended"
    }
}

# Send /exit to close gracefully
catch { send "/exit\r" }
catch { expect eof }
exit 0
