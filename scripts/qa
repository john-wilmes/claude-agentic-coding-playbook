#!/usr/bin/env bash
# qa - File-capable agentic CLI using the Anthropic API
# Usage: qa [OPTIONS] "prompt"
#        echo "prompt" | qa [OPTIONS]
set -euo pipefail

# ---------------------------------------------------------------------------
# Flag parsing
# ---------------------------------------------------------------------------
MODEL="claude-sonnet-4-6"
MAX_TURNS=10
AUTO_YES=false
NO_LOG=false
PROMPT_ARGS=()

usage() {
  cat <<'EOF'
Usage: qa [OPTIONS] "prompt"
       echo "prompt" | qa [OPTIONS]

A file-capable agentic CLI. Sends your prompt to Claude with bash and file
editing tools. Runs an agentic loop until the task is complete.

Options:
  --model MODEL      Override default model (default: claude-sonnet-4-6)
  --max-turns N      Maximum agentic turns (default: 10)
  --yes              Skip bash confirmation prompts
  --no-log           Skip session logging
  -h, --help         Show this help message

Environment:
  ANTHROPIC_API_KEY  Required. Your Anthropic API key.

Examples:
  qa "refactor this function to use async/await"
  qa --max-turns 5 "fix the failing test"
  qa --yes "add error handling to main.py"
  qa --model claude-opus-4-6 "complex architecture refactor"
EOF
  exit 0
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --model)
      if [[ "$#" -lt 2 || "$2" == --* ]]; then
        echo "ERROR: --model requires a model name" >&2; exit 1
      fi
      MODEL="$2"; shift ;;
    --max-turns)
      if [[ "$#" -lt 2 || "$2" == --* ]]; then
        echo "ERROR: --max-turns requires a number" >&2; exit 1
      fi
      MAX_TURNS="$2"; shift ;;
    --yes) AUTO_YES=true ;;
    --no-log) NO_LOG=true ;;
    -h|--help) usage ;;
    --) shift; PROMPT_ARGS+=("$@"); break ;;
    -*) echo "ERROR: Unknown flag: $1" >&2; exit 1 ;;
    *) PROMPT_ARGS+=("$1") ;;
  esac
  shift
done

# ---------------------------------------------------------------------------
# Check dependencies
# ---------------------------------------------------------------------------
if ! command -v python3 &>/dev/null; then
  echo "ERROR: python3 is required but not found on PATH." >&2
  exit 1
fi

if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
  echo "ERROR: ANTHROPIC_API_KEY environment variable is not set." >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Collect prompt
# ---------------------------------------------------------------------------
if [[ "${#PROMPT_ARGS[@]}" -gt 0 ]]; then
  PROMPT="${PROMPT_ARGS[*]}"
elif [[ ! -t 0 ]]; then
  PROMPT="$(cat)"
else
  echo "ERROR: No prompt provided. Pass as argument or via stdin." >&2
  echo "       Run 'qa --help' for usage." >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Invoke the embedded Python agentic loop
# ---------------------------------------------------------------------------
export QA_MODEL="$MODEL"
export QA_MAX_TURNS="$MAX_TURNS"
export QA_AUTO_YES="$AUTO_YES"
export QA_NO_LOG="$NO_LOG"
export QA_CWD="$(pwd)"

python3 - "$PROMPT" <<'PYTHON_EOF'
import json
import os
import subprocess
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timezone

# ---------------------------------------------------------------------------
# Configuration from env
# ---------------------------------------------------------------------------
MODEL       = os.environ["QA_MODEL"]
MAX_TURNS   = int(os.environ["QA_MAX_TURNS"])
AUTO_YES    = os.environ["QA_AUTO_YES"] == "true"
NO_LOG      = os.environ["QA_NO_LOG"] == "true"
CWD         = os.environ["QA_CWD"]
API_KEY     = os.environ["ANTHROPIC_API_KEY"]
PROMPT      = sys.argv[1]

LOG_DIR     = os.path.expanduser("~/.claude/logs")
LOG_FILE    = os.path.join(LOG_DIR, "qa.jsonl")

SYSTEM_PROMPT = (
    "You are a coding assistant with access to bash and a file editor. "
    "Work in the current directory. Be concise."
)

TOOLS = [
    {
        "name": "bash",
        "description": "Execute a bash command and return stdout/stderr",
        "input_schema": {
            "type": "object",
            "properties": {
                "command": {
                    "type": "string",
                    "description": "The bash command to execute"
                }
            },
            "required": ["command"]
        }
    },
    {
        "name": "str_replace_editor",
        "description": "View, create, or edit files using string replacement",
        "input_schema": {
            "type": "object",
            "properties": {
                "command": {
                    "type": "string",
                    "enum": ["view", "create", "str_replace"],
                    "description": "The operation to perform"
                },
                "path": {
                    "type": "string",
                    "description": "File path"
                },
                "file_text": {
                    "type": "string",
                    "description": "For create: full file content"
                },
                "old_str": {
                    "type": "string",
                    "description": "For str_replace: exact string to find"
                },
                "new_str": {
                    "type": "string",
                    "description": "For str_replace: replacement string (empty string to delete)"
                }
            },
            "required": ["command", "path"]
        }
    }
]


# ---------------------------------------------------------------------------
# API call
# ---------------------------------------------------------------------------
def call_api(messages):
    payload = json.dumps({
        "model": MODEL,
        "max_tokens": 4096,
        "system": SYSTEM_PROMPT,
        "tools": TOOLS,
        "messages": messages,
    }).encode("utf-8")

    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=payload,
        headers={
            "x-api-key": API_KEY,
            "anthropic-version": "2023-06-01",
            "content-type": "application/json",
        },
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=120) as resp:
            return json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="replace")
        print(f"\n[qa] API error {e.code}: {body}", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"\n[qa] Network error: {e.reason}", file=sys.stderr)
        sys.exit(1)


# ---------------------------------------------------------------------------
# Tool executors
# ---------------------------------------------------------------------------
DANGER_PATTERNS = [
    (r"\b(?:curl|wget|nc|ncat)\b.*\|", "network exfiltration via pipe"),
    (r"\b(?:curl|wget)\b.*https?://(?!localhost(?:[:/]|$))", "network request to external host"),
    (r"\b(?:curl|wget)\b.*--data", "network data exfiltration via --data"),
    (r"\b(?:curl|wget)\b.*-[dFT]\b", "network data exfiltration via upload flag"),
    (r"\b(?:nc|ncat)\b", "netcat network access"),
    (r">\s*~/\.(?:ssh|config|aws)", "redirect to sensitive config path"),
    (r"\brm\s+-rf\s+/", "destructive rm -rf /"),
    (r"\beval\b", "eval execution"),
    (r"\bpython3?\s+-c\b", "inline Python code execution"),
    (r"\bruby\s+-e\b", "inline Ruby code execution"),
    (r"\bperl\s+-e\b", "inline Perl code execution"),
    (r"\bnode\s+-e\b", "inline Node code execution"),
    (r"\bbase64\s+-[dD]\b.*\|", "base64 decode pipe execution"),
]
import re as _re
_DANGER_RES = [(_re.compile(p), label) for p, label in DANGER_PATTERNS]


def execute_bash(command):
    for pat, label in _DANGER_RES:
        if pat.search(command):
            return f"[blocked: dangerous pattern detected: {label}]"

    if not AUTO_YES:
        print(f"\n[qa] bash: {command}", file=sys.stderr)
        try:
            answer = input("Run this command? [y/N] ").strip().lower()
        except EOFError:
            answer = "n"
        if answer not in ("y", "yes"):
            return "[skipped by user]"

    try:
        result = subprocess.run(
            command,
            shell=True,
            capture_output=True,
            text=True,
            timeout=120,
            cwd=CWD,
        )
        output = result.stdout + result.stderr
    except subprocess.TimeoutExpired:
        output = "[error: command timed out after 120s]"
    except Exception as exc:
        output = f"[error: {exc}]"

    if len(output) > 10000:
        output = output[:10000] + "\n[...truncated]"
    return output


def execute_str_replace_editor(inputs):
    cmd  = inputs.get("command")
    path = inputs.get("path", "")

    # Resolve relative to CWD
    if not os.path.isabs(path):
        path = os.path.join(CWD, path)
    resolved = os.path.realpath(path)
    if not resolved.startswith(os.path.realpath(CWD) + os.sep) and resolved != os.path.realpath(CWD):
        return f"[error: path escapes working directory]"
    path = resolved

    if cmd == "view":
        print(f"\n[qa] str_replace_editor: view {path}", file=sys.stderr)
        if not os.path.exists(path):
            return f"[error: path not found: {path}]"
        if os.path.isdir(path):
            try:
                entries = sorted(os.listdir(path))
                return "\n".join(entries) if entries else "(empty directory)"
            except PermissionError as exc:
                return f"[error: {exc}]"
        try:
            with open(path, "r", encoding="utf-8", errors="replace") as fh:
                content = fh.read()
            if len(content) > 10000:
                content = content[:10000] + "\n[...truncated]"
            return content
        except Exception as exc:
            return f"[error: {exc}]"

    elif cmd == "create":
        file_text = inputs.get("file_text", "")
        print(f"\n[qa] str_replace_editor: create {path}", file=sys.stderr)
        try:
            os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
            with open(path, "w", encoding="utf-8") as fh:
                fh.write(file_text)
            return f"Created {path} ({len(file_text)} chars)"
        except Exception as exc:
            return f"[error: {exc}]"

    elif cmd == "str_replace":
        old_str = inputs.get("old_str", "")
        new_str = inputs.get("new_str", "")
        print(f"\n[qa] str_replace_editor: str_replace {path}", file=sys.stderr)
        if not os.path.exists(path):
            return f"[error: file not found: {path}]"
        try:
            with open(path, "r", encoding="utf-8") as fh:
                content = fh.read()
            if old_str not in content:
                return f"[error: old_str not found in {path}]"
            count = content.count(old_str)
            if count > 1:
                return f"[error: old_str matched {count} times in {path}; must be unique]"
            new_content = content.replace(old_str, new_str, 1)
            with open(path, "w", encoding="utf-8") as fh:
                fh.write(new_content)
            return f"Replaced 1 occurrence in {path}"
        except Exception as exc:
            return f"[error: {exc}]"

    else:
        return f"[error: unknown str_replace_editor command: {cmd!r}]"


def dispatch_tool(name, inputs):
    if name == "bash":
        return execute_bash(inputs.get("command", ""))
    elif name == "str_replace_editor":
        return execute_str_replace_editor(inputs)
    else:
        return f"[error: unknown tool: {name}]"


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
def write_log(entry):
    if NO_LOG:
        return
    try:
        os.makedirs(LOG_DIR, exist_ok=True)
        with open(LOG_FILE, "a", encoding="utf-8") as fh:
            fh.write(json.dumps(entry) + "\n")
    except Exception as exc:
        print(f"[qa] warning: could not write log: {exc}", file=sys.stderr)


# ---------------------------------------------------------------------------
# Agentic loop
# ---------------------------------------------------------------------------
def run():
    messages = [{"role": "user", "content": PROMPT}]
    turns = 0
    total_input_tokens = 0
    total_output_tokens = 0
    tools_used = set()
    start_ms = int(time.monotonic() * 1000)

    for turn in range(MAX_TURNS):
        turns += 1
        response = call_api(messages)

        # Accumulate token usage
        usage = response.get("usage", {})
        total_input_tokens  += usage.get("input_tokens", 0)
        total_output_tokens += usage.get("output_tokens", 0)

        stop_reason = response.get("stop_reason", "")
        content     = response.get("content", [])

        # Collect text blocks and tool_use blocks
        text_parts  = []
        tool_calls  = []
        for block in content:
            if block.get("type") == "text":
                text_parts.append(block.get("text", ""))
            elif block.get("type") == "tool_use":
                tool_calls.append(block)

        # Print any text the model emitted this turn
        for text in text_parts:
            if text.strip():
                print(text)

        if stop_reason == "end_turn" or not tool_calls:
            # Final answer — done
            break

        # Append assistant turn to history
        messages.append({"role": "assistant", "content": content})

        # Execute tools and collect results
        tool_results = []
        for tc in tool_calls:
            tool_name = tc.get("name", "")
            tool_id   = tc.get("id", "")
            inputs    = tc.get("input", {})
            tools_used.add(tool_name)

            result = dispatch_tool(tool_name, inputs)

            tool_results.append({
                "type": "tool_result",
                "tool_use_id": tool_id,
                "content": result,
            })

        # Append tool results as user turn
        messages.append({"role": "user", "content": tool_results})

    else:
        print(f"\n[qa] Reached max turns ({MAX_TURNS}). Stopping.", file=sys.stderr)

    # Write session log
    duration_ms = int(time.monotonic() * 1000) - start_ms
    write_log({
        "ts": datetime.now(timezone.utc).isoformat(),
        "model": MODEL,
        "prompt_head": PROMPT[:100],
        "turns": turns,
        "total_input_tokens": total_input_tokens,
        "total_output_tokens": total_output_tokens,
        "tools_used": sorted(tools_used),
        "duration_ms": duration_ms,
    })


if __name__ == "__main__":
    run()
PYTHON_EOF
